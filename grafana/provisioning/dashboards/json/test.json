          },
          "pluginVersion": "4.14.0",
          "queryType": "table",
          "rawSql": "WITH (SELECT max(event_date) FROM blood_ops.agg_inventory_3w_day_source_bank) AS latest_day\nSELECT\n  l.latitude AS latitude,\n  l.longitude AS longitude,\n  bb.bank_name AS bank,\n  sum(a.closing_units) AS value\nFROM blood_ops.agg_inventory_3w_day_source_bank a\nJOIN blood_ops.dim_blood_bank bb ON a.bank_id = bb.bank_id\nJOIN blood_ops.dim_location l ON bb.location_id = l.location_id\nWHERE a.event_date = latest_day\n  AND l.latitude != 0\n  AND l.longitude != 0\nGROUP BY latitude, longitude, bank\nORDER BY value DESC\nLIMIT 200",
          "refId": "A"
        }
      ],
      "title": "MAPBB",
      "type": "geomap"
