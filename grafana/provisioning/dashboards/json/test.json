          "pluginVersion": "4.14.0",
          "queryType": "table",
          "rawSql": "SELECT\n  toDateTime(a.event_date) AS time,\n  coalesce(s.source_name, concat('source_', toString(a.source_id))) AS metric,\n  sum(a.inflow_units) AS value\nFROM blood_ops.agg_inventory_2w_day_source a\nLEFT JOIN blood_ops.dim_source s ON a.source_id = s.source_id\nWHERE a.event_date >= today() - 60\nGROUP BY time, metric\nORDER BY time",
          "refId": "A"
        },
