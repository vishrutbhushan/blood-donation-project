          "pluginVersion": "4.14.0",
          "queryType": "table",
          "rawSql": "WITH (SELECT max(event_date) FROM blood_ops.agg_inventory_3w_day_source_bank) AS latest_day\nSELECT\n  concat(coalesce(s.source_name, concat('S', toString(a.source_id))), ' | ', coalesce(bb.bank_name, toString(a.bank_id))) AS bank_label,\n  a.closing_units\nFROM blood_ops.agg_inventory_3w_day_source_bank a\nLEFT JOIN blood_ops.dim_blood_bank bb\n  ON a.bank_id = bb.bank_id AND a.source_id = bb.source_id\nLEFT JOIN blood_ops.dim_source s\n  ON a.source_id = s.source_id\nWHERE a.event_date = latest_day\nORDER BY a.closing_units DESC\nLIMIT 15",
          "refId": "A"
        }
      ],
