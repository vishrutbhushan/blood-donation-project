          "pluginVersion": "4.15.0",
          "queryType": "table",
          "rawSql": "SELECT \n    metric, \n    AVG(daily_total) AS total_stock\nFROM (\n    SELECT \n        event_date, \n        component AS metric, \n        SUM(closing_balance_units) AS daily_total\n    FROM blood_ops.fact_inventory_day\n    WHERE $__timeFilter(event_date)\n    GROUP BY event_date, component\n)\nGROUP BY metric\nORDER BY total_stock ASC",
          "refId": "A"
        }
      ],
      "title": "Average Number of units on a given Day ",
      "type": "bargauge"
