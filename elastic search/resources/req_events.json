{
  "index_patterns": ["request_events*"],
  "template": {
    "settings": {
      "number_of_shards": 3,
      "number_of_replicas": 1,
      "refresh_interval": "5s"
    },
    "mappings": {
      "dynamic": "strict",
      "properties": {
        "source": { "type": "keyword" },
        "source_record_id": { "type": "keyword" },
        "event_time": { "type": "date" },
        "pincode": { "type": "keyword" },
        "location": { "type": "geo_point" },
        "blood_group": { "type": "keyword" },
        "component": { "type": "keyword" },
        "units_requested": { "type": "integer" },
        "required_by": { "type": "date" }
      }
    }
  }
}
